---
interface Props {
  title: string;
  date: Date;
  category: string;
  description: string;
  slug: string;
}

const { title, date, category, description, slug } = Astro.props;

const formatted = new Intl.DateTimeFormat('en-US', {
  year: 'numeric', month: 'short', day: 'numeric',
}).format(date);

const categoryColors: Record<string, string> = {
  antennas: 'text-emerald-400',
  ml:       'text-violet-400',
  rf:       'text-sky-400',
  optics:   'text-amber-400',
  dsp:      'text-rose-400',
  misc:     'text-zinc-400',
};
---

<article class="border border-zinc-800 rounded-lg p-5 hover:border-zinc-600 transition-colors group">
  <div class="flex items-center gap-3 mb-3">
    <a
      href={`/blog/${category}`}
      class:list={['text-xs font-mono hover:underline', categoryColors[category] ?? 'text-zinc-400']}
    >
      {category}
    </a>
    <time class="text-xs font-mono text-zinc-600">{formatted}</time>
  </div>
  <h2 class="text-base font-semibold text-zinc-100 mb-2 group-hover:text-emerald-400 transition-colors leading-snug">
    <a href={`/blog/${slug}`}>{title}</a>
  </h2>
  <p class="text-sm text-zinc-500">{description}</p>
</article>
