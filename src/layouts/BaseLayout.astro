---
import '../styles/global.css';
import Header from '../components/nav/Header.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Engineering portfolio — electronics, photonics, antennas, RF, signal processing.',
  ogImage = '/og-default.png',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <title>{title}</title>
  </head>
  <body class="bg-zinc-950 text-zinc-100 min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <footer class="border-t border-zinc-800 py-8 mt-16">
      <div class="max-w-5xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-zinc-500">
        <span>&copy; {new Date().getFullYear()} FraH90</span>
        <div class="flex gap-6">
          <a href="https://github.com/FraH90" target="_blank" rel="noopener" class="hover:text-zinc-200 transition-colors">GitHub</a>
          <a href="/contact" class="hover:text-zinc-200 transition-colors">Contact</a>
          <a href="/cv.pdf" target="_blank" class="hover:text-zinc-200 transition-colors">CV</a>
        </div>
      </div>
    </footer>
  </body>
</html>
