---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  domain: string;
  difficulty: 'beginner' | 'intermediate' | 'advanced';
  description: string;
}

const { title, domain, difficulty, description } = Astro.props;

const difficultyColors = {
  beginner:     'text-emerald-400 bg-emerald-400/10',
  intermediate: 'text-amber-400 bg-amber-400/10',
  advanced:     'text-rose-400 bg-rose-400/10',
};
---

<BaseLayout title={`${title} — frah90`} description={description}>
  <div class="max-w-4xl mx-auto px-4 py-12">

    <!-- Header -->
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-xs font-mono px-2 py-0.5 rounded bg-zinc-800 text-zinc-400">{domain}</span>
        <span class:list={['text-xs font-mono px-2 py-0.5 rounded', difficultyColors[difficulty]]}>
          {difficulty}
        </span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-zinc-50 mb-3">{title}</h1>
      <p class="text-zinc-400 text-lg">{description}</p>
    </header>

    <!-- Concept Introduction -->
    <section class="mb-10">
      <h2 class="text-xs font-mono uppercase tracking-widest text-zinc-500 mb-4">Concept</h2>
      <div class="prose prose-invert prose-zinc max-w-none
        prose-headings:text-zinc-200 prose-p:text-zinc-300">
        <slot name="intro" />
      </div>
    </section>

    <!-- Equations -->
    <section class="mb-10">
      <h2 class="text-xs font-mono uppercase tracking-widest text-zinc-500 mb-4">Equations</h2>
      <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6 overflow-x-auto text-zinc-200">
        <slot name="equations" />
      </div>
    </section>

    <!-- Interactive Demo -->
    <section class="mb-10">
      <h2 class="text-xs font-mono uppercase tracking-widest text-zinc-500 mb-4">Interactive Demo</h2>
      <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-4 sm:p-6">
        <slot name="demo" />
      </div>
    </section>

    <!-- Physical Interpretation -->
    <section class="mb-10">
      <h2 class="text-xs font-mono uppercase tracking-widest text-zinc-500 mb-4">What This Means Physically</h2>
      <div class="prose prose-invert prose-zinc max-w-none
        prose-headings:text-zinc-200 prose-p:text-zinc-300">
        <slot name="interpretation" />
      </div>
    </section>

    <div class="pt-8 border-t border-zinc-800">
      <a href="/demos" class="text-sm font-mono text-zinc-500 hover:text-emerald-400 transition-colors">
        ← back to demos
      </a>
    </div>

  </div>
</BaseLayout>
