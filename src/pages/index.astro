---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllPosts } from '../lib/posts';
import PostCard from '../components/blog/PostCard.astro';

const recentPosts = (await getAllPosts()).slice(0, 3);

const domains = ['Antennas & Arrays', 'Photonics & Optics', 'RF & Transmission Lines', 'Signal Processing & DSP'];
---

<BaseLayout title="frah90.github.io" description="RF & Photonics Engineer. Technical writing on antennas, RF, optical systems, and signal processing.">
  <div class="max-w-5xl mx-auto px-4">

    <!-- Hero -->
    <section class="pt-14 pb-10">
      <h1 class="text-xl sm:text-2xl font-semibold text-zinc-200 mb-1">
        RF & Photonics Engineer
      </h1>
      <p class="text-zinc-500 text-sm mb-5">
        Building and experimenting with things that deal with waves.
      </p>
      <div class="flex flex-wrap gap-x-4 gap-y-1 text-[11px] font-mono text-zinc-600">
        <span>Antennas</span>
        <span>·</span>
        <span>RF</span>
        <span>·</span>
        <span>Photonics</span>
        <span>·</span>
        <span>Signal Processing</span>
      </div>
    </section>

    <!-- Recent Articles -->
    {recentPosts.length > 0 && (
      <section class="border-t border-zinc-800 pt-10 pb-16">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xs font-mono uppercase tracking-widest text-zinc-500">Recent Articles</h2>
          <a href="/blog" class="text-xs font-mono text-emerald-400 hover:underline">view all →</a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {recentPosts.map(post => (
            <PostCard
              title={post.data.title}
              date={post.data.date}
              category={post.data.category}
              description={post.data.description}
              slug={post.id}
            />
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>
