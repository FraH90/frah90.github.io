---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllPosts } from '../lib/posts';
import PostCard from '../components/blog/PostCard.astro';

const recentPosts = (await getAllPosts()).slice(0, 3);

const domains = ['Antennas & Arrays', 'Photonics & Optics', 'RF & Transmission Lines', 'Signal Processing & DSP'];
---

<BaseLayout title="frah90 — Engineering Portfolio">
  <div class="max-w-5xl mx-auto px-4">

    <!-- Hero — compact -->
    <section class="pt-14 pb-10">
      <p class="text-emerald-400 font-mono text-sm mb-2">hi, I'm FraH</p>
      <h1 class="text-3xl sm:text-5xl font-bold text-zinc-50 leading-tight mb-3">
        Electronics & Photonics Engineer
      </h1>
      <p class="text-zinc-400 max-w-2xl mb-5">
        Antennas, RF, photonics, signal processing.
        Technical articles with embedded interactive simulations.
      </p>
      <!-- Domains inline, very subtle -->
      <div class="flex flex-wrap gap-2">
        {domains.map(d => (
          <span class="text-[11px] font-mono text-zinc-600 border border-zinc-800 px-2 py-0.5 rounded">
            {d}
          </span>
        ))}
      </div>
    </section>

    <!-- Recent Articles -->
    {recentPosts.length > 0 && (
      <section class="border-t border-zinc-800 pt-10 pb-16">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xs font-mono uppercase tracking-widest text-zinc-500">Recent Articles</h2>
          <a href="/blog" class="text-xs font-mono text-emerald-400 hover:underline">view all →</a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {recentPosts.map(post => (
            <PostCard
              title={post.data.title}
              date={post.data.date}
              category={post.data.category}
              description={post.data.description}
              slug={post.id}
            />
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>
