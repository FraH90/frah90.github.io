---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import { getAllPosts, getAllCategories } from '../../lib/posts';

const posts = await getAllPosts();
const categories = await getAllCategories();
---

<BaseLayout title="Blog — frah90" description="Technical articles on antennas, RF, photonics, signal processing, and ML.">
  <div class="max-w-5xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold text-zinc-50 mb-4">Blog</h1>
    <p class="text-zinc-400 mb-8">Technical writing on things I actually work with.</p>

    <!-- Category filters -->
    {categories.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-10">
        <a href="/blog" class="text-xs font-mono px-3 py-1 rounded bg-zinc-800 text-zinc-300 hover:bg-zinc-700 transition-colors">
          all
        </a>
        {categories.map(cat => (
          <a
            href={`/blog/${cat}`}
            class="text-xs font-mono px-3 py-1 rounded bg-zinc-800 text-zinc-400 hover:bg-zinc-700 hover:text-zinc-200 transition-colors"
          >
            {cat}
          </a>
        ))}
      </div>
    )}

    {posts.length === 0 ? (
      <div class="border border-dashed border-zinc-800 rounded-lg p-12 text-center">
        <p class="text-zinc-500 font-mono text-sm">No posts yet. Coming soon.</p>
      </div>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {posts.map(post => (
          <PostCard
            title={post.data.title}
            date={post.data.date}
            category={post.data.category}
            description={post.data.description}
            slug={post.id}
            tags={post.data.tags}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
