---
import BaseLayout from '../layouts/BaseLayout.astro';

const skillGroups = [
  {
    label: 'Antennas & Arrays',
    items: ['Phased array design', 'Array factor analysis', 'Beam steering', 'Near/far field', 'HFSS / CST'],
  },
  {
    label: 'RF & Microwave',
    items: ['Transmission line theory', 'Smith chart / impedance matching', 'S-parameters', 'LTspice', 'VNA measurements'],
  },
  {
    label: 'Photonics & Optics',
    items: ['Gaussian beam propagation', 'Mode field analysis', 'Fiber optics', 'Optical resonators', 'Dispersion modeling'],
  },
  {
    label: 'Signal Processing',
    items: ['Fourier analysis (DFT/FFT)', 'Filter design (FIR/IIR)', 'Spectral estimation', 'Windowing', 'Sampling theory'],
  },
  {
    label: 'Simulation & Software',
    items: ['Python (NumPy, SciPy, Plotly)', 'MATLAB / Octave', 'Jupyter notebooks', 'Git', 'Linux'],
  },
  {
    label: 'Machine Learning',
    items: ['Neural networks (PyTorch)', 'Applied ML for signal data', 'Feature engineering', 'Model evaluation'],
  },
];
---

<BaseLayout title="About — frah90" description="About FraH — electronics and photonics engineer.">
  <div class="max-w-4xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold text-zinc-50 mb-8">About</h1>

    <div class="prose prose-invert prose-zinc max-w-none
      prose-headings:font-mono prose-headings:text-zinc-300
      prose-p:text-zinc-400 prose-a:text-emerald-400 mb-16">
      <p>
        I'm an engineer working in electronics, photonics, and RF systems.
        My background spans antenna design and simulation, optical system modeling,
        transmission line theory, and signal processing.
      </p>
      <p>
        This site is a living document of things I actually understand — not a CV.
        Each demo and article represents something I've worked through from first principles.
      </p>
    </div>

    <h2 class="text-xs font-mono uppercase tracking-widest text-zinc-500 mb-6">Skills</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-16">
      {skillGroups.map(group => (
        <div class="border border-zinc-800 rounded-lg p-5">
          <h3 class="text-xs font-mono uppercase tracking-widest text-emerald-400 mb-4">{group.label}</h3>
          <ul class="space-y-1.5">
            {group.items.map(item => (
              <li class="text-sm text-zinc-400 flex items-start gap-2">
                <span class="text-zinc-600 mt-0.5">—</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <h2 class="text-xs font-mono uppercase tracking-widest text-zinc-500 mb-6">Contact</h2>
    <div class="space-y-3">
      <a
        href="https://github.com/FraH90"
        target="_blank"
        rel="noopener"
        class="flex items-center gap-4 border border-zinc-800 rounded-lg p-4 hover:border-zinc-600 transition-colors group"
      >
        <span class="text-zinc-500 font-mono text-sm w-16">GitHub</span>
        <span class="text-zinc-300 group-hover:text-emerald-400 transition-colors">github.com/FraH90</span>
      </a>
      <a
        href="mailto:frah.221190@gmail.com"
        class="flex items-center gap-4 border border-zinc-800 rounded-lg p-4 hover:border-zinc-600 transition-colors group"
      >
        <span class="text-zinc-500 font-mono text-sm w-16">Email</span>
        <span class="text-zinc-300 group-hover:text-emerald-400 transition-colors">frah.221190@gmail.com</span>
      </a>
      <a
        href="/cv.pdf"
        target="_blank"
        class="flex items-center gap-4 border border-zinc-800 rounded-lg p-4 hover:border-zinc-600 transition-colors group"
      >
        <span class="text-zinc-500 font-mono text-sm w-16">CV</span>
        <span class="text-zinc-300 group-hover:text-emerald-400 transition-colors">Download PDF</span>
      </a>
    </div>
  </div>
</BaseLayout>
